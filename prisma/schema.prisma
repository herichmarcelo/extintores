// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                String            @id @default(uuid())
  nome              String
  email             String            @unique
  emailVerified     DateTime?
  image             String?
  senha             String
  perfil            String            // Administrador, SESMT, Inspetor, Gestor
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  accounts          Account[]
  sessions          Session[]
  inspecoesExtintor InspecaoExtintor[]
  inspecoesHidrante InspecaoHidrante[]
  unidadesAcesso    UnidadeAcesso[]
  setoresAcesso     SetorAcesso[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Unidade {
  id     String @id @default(uuid())
  nome   String
  cidade String
  estado String

  extintores Extintor[]
  hidrantes  Hidrante[]
  setores    Setor[]
  acessos    UnidadeAcesso[]
}

model Setor {
  id        String  @id @default(uuid())
  nome      String
  unidadeId String
  unidade   Unidade @relation(fields: [unidadeId], references: [id])

  extintores Extintor[]
  hidrantes  Hidrante[]
  acessos    SetorAcesso[]
}

model UnidadeAcesso {
  id        String  @id @default(uuid())
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  unidadeId String
  unidade   Unidade @relation(fields: [unidadeId], references: [id])

  @@unique([usuarioId, unidadeId])
}

model SetorAcesso {
  id        String  @id @default(uuid())
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  setorId   String
  setor     Setor @relation(fields: [setorId], references: [id])

  @@unique([usuarioId, setorId])
}

model Extintor {
  id            String   @id @default(uuid())
  codigo        String
  localizacao   String
  setorId       String?
  setor         Setor?   @relation(fields: [setorId], references: [id])
  tipo          String
  capacidade    String
  validadeCarga DateTime
  foto          String?  // Foto do equipamento cadastrado

  unidadeId String
  unidade   Unidade @relation(fields: [unidadeId], references: [id])

  inspecoes InspecaoExtintor[]

  @@unique([unidadeId, codigo])
}

model Hidrante {
  id          String @id @default(uuid())
  codigo      String
  localizacao String
  foto        String?  // Foto do equipamento cadastrado
  setorId     String?
  setor       Setor?   @relation(fields: [setorId], references: [id])

  unidadeId String
  unidade   Unidade @relation(fields: [unidadeId], references: [id])

  inspecoes InspecaoHidrante[]

  @@unique([unidadeId, codigo])
}

model InspecaoExtintor {
  id String @id @default(uuid())

  extintorId String
  extintor   Extintor @relation(fields: [extintorId], references: [id])

  sinalizacao Boolean
  manometro   Boolean
  lacre       Boolean
  mangueira   Boolean
  pintura     Boolean
  seloInmetro Boolean

  observacao   String?
  foto         String?
  status       String // Conforme, Não Conforme
  dataInspecao DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model InspecaoHidrante {
  id String @id @default(uuid())

  hidranteId String
  hidrante   Hidrante @relation(fields: [hidranteId], references: [id])

  localAcessivel    Boolean // O local está acessível?
  sinalizado        Boolean // Está sinalizado?
  estadoMangueiras  Boolean // Qual o estado das mangueiras?
  enroladasCorretamente Boolean // Estão enroladas corretamente?
  esguichosNoLocal  Boolean // Os esguichos estão no local?
  esguichosBoasCondicoes Boolean // Estão em boas condições?
  semVazamentos     Boolean // Há vazamentos?
  valvulaFechada    Boolean // A válvula está fechada?
  temChaveStorz     Boolean // Tem Chave storz?
  estadoPintura     Boolean // Qual o estado da pintura?
  proximoTesteHidrostatico DateTime? // Próximo teste hidrostáticos?

  observacao   String?
  foto         String?
  status       String // Conforme, Não Conforme
  dataInspecao DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}
